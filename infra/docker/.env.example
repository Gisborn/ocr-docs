# Production Environment Variables for API-Scan
# Скопируйте этот файл в .env и заполните реальными значениями

# ── GitHub Container Registry ────────────────────────────────────
GHCR_REGISTRY=ghcr.io
GHCR_REPOSITORY=your-github-username/ocr-passport

# ── Domains ──────────────────────────────────────────────────────
# Домен для API и webhook'ов (например: api.api-scan.ru)
API_DOMAIN=api-scan.example.com
# Домен для личного кабинета (например: cabinet.api-scan.ru)
CABINET_DOMAIN=cabinet.api-scan.example.com

# ── SSL / Let's Encrypt ──────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@example.com

# ── PostgreSQL Main ──────────────────────────────────────────────
POSTGRES_USER=api_scan
POSTGRES_PASSWORD=CHANGE_ME_32_CHARS_MIN
POSTGRES_DB=api_scan

# ── PostgreSQL Billing ───────────────────────────────────────────
POSTGRES_BILLING_USER=billing
POSTGRES_BILLING_PASSWORD=CHANGE_ME_32_CHARS_MIN
POSTGRES_BILLING_DB=billing_db

# ── Redis ────────────────────────────────────────────────────────
# Redis не требует пароля по умолчанию в текущей конфигурации

# ── Billing / ЮКасса ─────────────────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=live_yookassa_secret_key
BILLING_SERVICE_TOKEN=generate_random_32_char_string
YOOKASSA_IP_WHITELIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25

# ── OCR / Yandex Vision ──────────────────────────────────────────
YANDEX_VISION_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_yandex_folder_id
YANDEX_VISION_USE_V2=true
YANDEX_VISION_MODEL=passport

# ── OCR / VK Vision (fallback) ───────────────────────────────────
VK_VISION_API_KEY=
VK_FOLDER_ID=

# ── OCR Settings ─────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.80
