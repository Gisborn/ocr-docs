# Yandex Vision OCR (v2 — рекомендуется)
YANDEX_VISION_API_KEY=your_api_key_here
YANDEX_VISION_USE_V2=true
YANDEX_VISION_MODEL=passport

# Yandex Vision v1 (legacy, требуется только если USE_V2=false)
YANDEX_FOLDER_ID=your_folder_id_here

# VK Vision (fallback)
VK_VISION_API_KEY=your_vk_api_key_here
VK_FOLDER_ID=your_vk_folder_id_here

# Billing Service
BILLING_SERVICE_TOKEN=internal-service-token
