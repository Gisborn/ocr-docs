    "definitions": {
        "handler.ErrorResponse": {
            "description": "Error response with code and message",
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "UNAUTHORIZED"
                },
                "error": {
                    "type": "string",
                    "example": "invalid api key"
                }
            }
        },
        "handler.HealthResponse": {
            "description": "Health check response",
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        },
        "handler.RecognizeResponse": {
            "description": "OCR recognition result with passport fields",
            "type": "object",
            "properties": {
                "confidences": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number",
                        "format": "float64"
                    }
                },
                "document_type": {
                    "type": "string",
                    "example": "passport_rf"
                },
                "fields": {
                    "type": "object",
                    "additionalProperties": true
                },
                "provider": {
                    "type": "string",
                    "example": "yandex"
                },
                "request_id": {
                    "type": "string",
                    "example": "req_abc123"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "type": "apiKey",
            "name": "X-Api-Key",
            "in": "header"
        }
    }
}